# Your full domain name (e.g., example.duckdns.org or myapp.com)
# This is used by Certbot to request the SSL certificate and by Nginx as server_name.
DOMAIN=example.duckdns.org

# Optional: Basic Authentication. 
# Set to 'Restricted Area' (or any string) to enable, or 'off' to disable.
# If enabled, you must also provide a .htpasswd file in the proxy directory.
BASIC_AUTH=off

# Certbot staging mode (1 = test/staging, 0 = production). 
# Use 1 during setup to avoid hitting Let's Encrypt rate limits.
STAGING=1

# Email address for Let's Encrypt to send certificate expiration notifications.
CERTBOT_EMAIL=your-email@example.com

# Your DuckDNS token from the dashboard.
DUCKDNS_TOKEN=your-duckdns-token

# Your DuckDNS subdomain (e.g., if domain is example.duckdns.org, use 'example').
SUBDOMAIN=example
