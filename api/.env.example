# If set to 1, all SQL queries will be printed to standard output. This is useful for debugging.
SQL_ECHO=1

# The amount of points a new user has when they are created.
INITIAL_POINTS=1000

# The algorithm used to sign the JWTs (you shouldn't change this really).
ALGORITHM=HS256

# The amount of days a JWT is valid for.
JWT_EXP_DAYS=1
